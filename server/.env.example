# ─────────────────────────────────────────────────────────────
# Flash Sale — Server Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Database (NeonDB — PostgreSQL) ───────────────────────────
# IMPORTANT for Prisma v7 + NeonDB:
#   Use your DIRECT (non-pooled) connection string for DATABASE_URL.
#   In your NeonDB dashboard → Connection Details → toggle "Pooled connection" OFF.
#   The direct URL allows prisma migrate dev to run DDL statements without issues.
#
#   Format: postgresql://<user>:<password>@<host>/<dbname>?sslmode=require
#   (The direct host does NOT contain "-pooler" in the hostname)
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxxx.us-east-1.aws.neon.tech/flashsale?sslmode=require"

# ── JWT ──────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -base64 64
JWT_SECRET="your-super-secret-jwt-key-change-this"
JWT_EXPIRES_IN="7d"

# ── Cookie ───────────────────────────────────────────────────
COOKIE_DOMAIN="localhost"

# ── Cloudinary ───────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ── CORS ─────────────────────────────────────────────────────
# Next.js dev server origin (comma-separated for multiple)
ALLOWED_ORIGINS="http://localhost:3000"
